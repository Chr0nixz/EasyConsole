{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://116.172.93.164:28080/*" },
        { "url": "http://116.172.93.164:33000/*" },
        { "url": "http://127.0.0.1:*/*" },
        { "url": "http://localhost:*/*" }
      ]
    },
    "websocket:default",
    "dialog:default",
    "fs:default",
    "fs:write-files",
    {
      "identifier": "fs:scope",
      "allow": [
        "$DOWNLOAD/**"
      ]
    }
  ]
}
