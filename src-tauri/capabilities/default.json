{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions on desktop runtimes",
  "platforms": [
    "linux",
    "macOS",
    "windows"
  ],
  "windows": [
    "main",
    "ssh-*"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*:*/*" },
        { "url": "https://*:*/*" }
      ]
    },
    "websocket:default",
    "notification:default",
    "updater:default",
    "process:default",
    "dialog:default",
    "fs:default",
    "fs:write-files",
    {
      "identifier": "fs:scope",
      "allow": [
        "$DOWNLOAD/**"
      ]
    },
    "opener:default",
    "deep-link:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister"
  ]
}
