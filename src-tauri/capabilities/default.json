{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions on desktop runtimes",
  "platforms": [
    "linux",
    "macOS",
    "windows"
  ],
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*:*/*" },
        { "url": "https://*:*/*" }
      ]
    },
    "websocket:default",
    "notification:default",
    "updater:default",
    "process:default",
    "dialog:default",
    "fs:default",
    "fs:write-files",
    {
      "identifier": "fs:scope",
      "allow": [
        "$DOWNLOAD/**",
        "$DOCUMENT/**",
        "$DESKTOP/**"
      ]
    },
    "opener:default"
  ]
}
