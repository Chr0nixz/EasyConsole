{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "EasyConsole",
  "mainBinaryName": "EasyConsole",
  "version": "0.1.0",
  "identifier": "com.easyconsole.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm.cmd run dev:tauri",
    "beforeBuildCommand": "npm.cmd run build:desktop"
  },
  "app": {
    "windows": [
      {
        "title": "EasyConsole",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost blob: data:; font-src 'self' data:; connect-src 'self' http://116.172.93.164:28080 http://116.172.93.164:33000 ws://116.172.93.164:28080 http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/easy-console",
      "binaries/easy-console-mcp"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
