{
  "name": "easy-console",
  "private": true,
  "version": "0.4.7",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:tauri": "vite --host 127.0.0.1 --port 1420 --strictPort",
    "build": "tsc -b && vite build",
    "build:desktop": "node tools/easy-console/build-desktop.mjs",
    "build:sidecars": "node tools/easy-console/build-sidecars.mjs",
    "build:web": "tsc -b && vite build",
    "ec": "tsx tools/easy-console/cli-entry.ts",
    "ec:mcp": "tsx tools/easy-console/mcp-entry.ts",
    "preview": "vite preview --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:android:init": "tauri android init",
    "tauri:android:dev": "tauri android dev",
    "tauri:android:build": "tauri android build",
    "typecheck": "tsc -b --noEmit",
    "typecheck:tools": "tsc -p tsconfig.tools.json --noEmit",
    "version:check": "node tools/easy-console/version-check.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "bin": {
    "easy-console": "./tools/easy-console/cli-entry.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-table": "^8.21.2",
    "@tanstack/react-virtual": "^3.14.3",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-websocket": "^2.4.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "lucide-react": "^1.16.0",
    "proper-lockfile": "^4.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "recharts": "^2.15.0",
    "tailwind-merge": "^3.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^25.9.1",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@yao-pkg/pkg": "^6.19.0",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.24.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
